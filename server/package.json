{
  "name": "@adelia/server",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "Authoritative game server: Fastify REST + ws + tick scheduler + Kysely/Postgres.",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "migrate": "tsx --env-file=../.env src/db/migrate.ts",
    "seed": "tsx --env-file=../.env src/db/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@adelia/shared": "*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.2.0",
    "kysely": "^0.27.4",
    "pg": "^8.13.0",
    "ws": "^8.18.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0"
  }
}
