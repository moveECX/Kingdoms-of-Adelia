{
  "name": "aldermark",
  "version": "0.0.0",
  "private": true,
  "description": "Aldermark — browser MMO city-building strategy game (clean-room, original IP).",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w shared && npm run build -w server && npm run build -w client",
    "typecheck": "tsc -b --pretty",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "migrate": "npm run migrate -w server",
    "seed": "npm run seed -w server"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "npm-run-all2": "^7.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
