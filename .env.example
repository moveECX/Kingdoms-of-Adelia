# Nach .env kopieren und anpassen. Wird von docker-compose.yml und dem Server genutzt.
POSTGRES_USER=adelia
POSTGRES_PASSWORD=adelia
POSTGRES_DB=adelia
POSTGRES_PORT=5432

# Der Server liest diesen Connection-String (entspricht standardmäßig den Werten oben).
DATABASE_URL=postgres://adelia:adelia@localhost:5432/adelia

# Server
PORT=3000
NODE_ENV=development
# Secret für Session-/Cookie-Signierung — generiere ein echtes, committe es nie.
SESSION_SECRET=change-me-in-your-local-.env
