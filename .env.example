# Copy to .env and adjust. Used by docker-compose.yml and the server.
POSTGRES_USER=aldermark
POSTGRES_PASSWORD=aldermark
POSTGRES_DB=aldermark
POSTGRES_PORT=5432

# Server reads this connection string (matches the values above by default).
DATABASE_URL=postgres://aldermark:aldermark@localhost:5432/aldermark

# Server
PORT=3000
NODE_ENV=development
# Secret for session/cookie signing — generate a real one, never commit it.
SESSION_SECRET=change-me-in-your-local-.env
